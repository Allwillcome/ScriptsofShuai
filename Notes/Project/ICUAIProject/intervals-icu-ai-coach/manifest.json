{
  "manifest_version": 3,
  "name": "Intervals.icu AI Coach",
  "version": "2.1",
  "description": "Embedded AI analysis for Intervals.icu activities.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://intervals.icu/*",
    "https://*.openai.com/*",
    "https://*.deepseek.com/*",
    "https://*.api2d.net/*",
    "https://*.anthropic.com/*",
    "https://*.googleapis.com/*",
    "https://*.cohere.ai/*",
    "https://*.cohere.com/*",
    "https://*.baidubce.com/*",
    "https://*.aliyuncs.com/*",
    "https://*.bigmodel.cn/*",
    "https://*.moonshot.cn/*",
    "https://*.xfyun.cn/*",
    "https://*.azure.com/*",
    "https://*.huggingface.co/*"
  ],
  "action": {
    "default_title": "Intervals AI Coach (Click to reset UI)"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://intervals.icu/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["prompt.txt"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}